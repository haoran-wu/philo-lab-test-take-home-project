# Preferred: one key for all models through OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=vlm-blindspot-discovery

# Optional model-ID overrides for OpenRouter.
MODEL_ID_GEMINI_3_1_PRO=google/gemini-3.1-pro-preview
MODEL_ID_GEMINI_3_FLASH=google/gemini-3-flash-preview
MODEL_ID_QWEN_3_5_OMNI=qwen/qwen3.5-397b-a17b
MODEL_ID_GPT_5_4=openai/gpt-5.4

# Optional direct-provider fallbacks.
OPENAI_API_KEY=
GOOGLE_API_KEY=
DASHSCOPE_API_KEY=
